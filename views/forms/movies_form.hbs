<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-body: #0b0e14;      
        --bg-card: #151921;      
        --bg-input: #1c222d;     
        --text-main: #ffffff;    
        --text-muted: #718096;   
        --accent-blue: #3b82f6;  
        --border: #2d3748;       
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        color: var(--text-main);
        padding: 80px 20px;
        -webkit-font-smoothing: antialiased;
    }

    h3 {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 25px;
        text-align: center;
        letter-spacing: -0.02em;
    }

    .edit-container {
        background-color: var(--bg-card);
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        max-width: 400px;
        margin: 0 auto;
        border: 1px solid var(--border);
    }

    label { 
        display: block; 
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 20px;
        margin-bottom: 8px;
    }

    input, select { 
        width: 100%; 
        padding: 14px 16px; 
        margin-top: 5px; 
        background-color: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: white;
        font-size: 15px;
        font-family: inherit;
        box-sizing: border-box; 
        transition: all 0.2s ease;
    }

    input:focus, select:focus {
        outline: none;
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    }

    select {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23718096%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
        background-repeat: no-repeat;
        background-position: right 16px top 50%;
        background-size: 10px auto;
    }

    .btn-save {
        margin-top: 35px; 
        width: 100%; 
        padding: 16px;
        background-color: var(--accent-blue); 
        color: white;
        border: none; 
        border-radius: 12px; 
        cursor: pointer; 
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
        filter: brightness(1.1);
    }

    .back-link { 
        display: block; 
        margin-top: 25px; 
        text-align: center; 
        color: var(--text-muted); 
        text-decoration: none; 
        font-size: 14px;
        font-weight: 600;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: white;
    }
</style>

<div class="edit-container">
    <h3>Edit Movie</h3>
    
    <form action="/movies/edit/{{movie.id}}" method="POST">
        <label>Movie Title</label>
        <input type="text" name="title" value="{{movie.title}}" required>

        <label>Director</label>
        <input type="text" name="director" value="{{movie.director}}" required>

        <label>Poster URL</label>
        <input type="url" name="poster_url" value="{{movie.poster_url}}">

        <label>Genre</label>
        <select name="genre" required>
            <option value="{{movie.genre}}" selected hidden>{{#if movie.genre}}{{movie.genre}}{{else}}Select Genre{{/if}}</option>
            <option value="Action">Action</option>
            <option value="Sci-Fi">Sci-Fi</option>
            <option value="Drama">Drama</option>
            <option value="Comedy">Comedy</option>
            <option value="Thriller">Thriller</option>
            <option value="Horror">Horror</option>
            <option value="Romance">Romance</option>
            <option value="Fantasy">Fantasy</option>
            <option value="Animation">Animation</option>
            <option value="Mystery">Mystery</option>
            <option value="Crime">Crime</option>
        </select>

        <label>Status</label>
        <select name="status" required>
            <option value="{{movie.status}}" selected hidden>{{#if movie.status}}{{movie.status}}{{else}}Select Status{{/if}}</option>
            <option value="Watched">Watched</option>
            <option value="Plan to Watch">Plan to Watch</option>
        </select>

        <label>Release Year</label>
        <input type="number" name="release_year" value="{{movie.release_year}}" required>

        <label>Rating</label>
        <input type="number" step="0.1" name="rating" value="{{movie.rating}}" required>

        <button type="submit" class="btn-save">Update Movie</button>
    </form>

    <a href="/movies" class="back-link">← Cancel and go back</a>
</div>