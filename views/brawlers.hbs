<div style="padding: 20px; font-family: sans-serif;">
    <h1>Brawlers Management</h1>

    <a href="/brawlers/create" style="display: inline-block; margin-bottom: 20px; padding: 10px 15px; background: #28a745; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">
        + Add New Brawler
    </a>

    <table border="1" style="width: 100%; border-collapse: collapse; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <thead style="background: #f8f9fa;">
            <tr>
                <th style="padding: 12px; text-align: left;">Name</th>
                <th style="padding: 12px; text-align: left;">Rarity</th>
                <th style="padding: 12px; text-align: left;">Class</th>
                <th style="padding: 12px; text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each brawlers}}
            <tr>
                <td style="padding: 10px;">{{this.name}}</td>
                <td style="padding: 10px;">{{this.rarity}}</td>
                <td style="padding: 10px;">{{this.class}}</td>
                <td style="padding: 10px; text-align: center;">
                    <a href="/brawlers/update?name={{this.name}}" style="color: #007bff; margin-right: 15px; text-decoration: none; font-weight: 500;">Edit</a>

                    <form action="/brawlers/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete {{this.name}}?')">
                        <input type="hidden" name="name" value="{{this.name}}">
                        <button type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer; text-decoration: underline; padding: 0; font-size: 16px; font-family: inherit;">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>