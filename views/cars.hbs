<!DOCTYPE html>
<html lang="uk" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <title>Управління автомобілями</title>
    <style>

        :root {
           
            --text-main: #f0f4f8;
            --text-label: #e2e8f0;
            --text-muted: #9fb3c8;
            --bg-card: rgba(15, 23, 42, 0.85);
            --input-bg: #1e293b;
            --input-border: #334155;
            --input-focus: #0f172a;
            --input-text: #ffffff;
            --divider: rgba(51, 65, 85, 0.8);
            --title-color: #ffffff;
            --title-shadow-1: rgba(56, 189, 248, 0.3); 
            --title-shadow-2: rgba(0, 0, 0, 0.9);
            --btn-back-bg: #334155;
            --btn-back-text: #e2e8f0;
            --btn-controls-bg: rgba(30, 41, 59, 0.8);
            --bg-overlay: rgba(15, 23, 42, 0.4); 
        }

        [data-theme="light"] {+
            --text-main: #1e293b;
            --text-label: #334155;
            --text-muted: #64748b;
            --bg-card: rgba(255, 255, 255, 0.85); 
            --input-bg: #f8fafc;
            --input-border: #cbd5e1;
            --input-focus: #ffffff;
            --input-text: #0f172a;
            --divider: rgba(203, 213, 224, 0.8);
            --title-color: #0f172a;
            --title-shadow-1: rgba(255, 255, 255, 0.8);
            --title-shadow-2: rgba(0, 0, 0, 0.1);
            --btn-back-bg: #e2e8f0;
            --btn-back-text: #1e293b;
            --btn-controls-bg: rgba(255, 255, 255, 0.9);
            --bg-overlay: rgba(255, 255, 255, 0.1); 
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            min-height: 100%;
            font-family: Arial, sans-serif;
            color: var(--text-main);
            transition: color 0.3s ease;
        }

     
        #bg-image {
            position: fixed;
            top: 0; 
            left: 0; 
            right: 0; 
            bottom: 0;
            background-image: url('background.png'); 
            background-size: cover;
            background-position: center;
            z-index: -100;
        }

        #bg-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: -90; 
            background: var(--bg-overlay);
            pointer-events: none; 
            transition: background 0.4s ease;
            backdrop-filter: blur(1px); 
        }

        .main-title {
            font-family: 'Sofachrome', sans-serif;
            font-style: italic;
            text-align: center;
            font-size: 56px; 
            color: var(--title-color);
            margin-top: 10px;
            margin-bottom: 35px;
            letter-spacing: 4px;
            text-shadow: 0 0 10px var(--title-shadow-1), 
                         0 5px 15px var(--title-shadow-2); 
            transition: color 0.3s ease, text-shadow 0.3s ease;
        }

        .wrapper {
            max-width: 800px;
            margin: auto;
            padding: 20px;
        }

        h2 { 
            color: var(--title-color); 
            border-bottom: 2px solid var(--divider); 
            padding-bottom: 10px; 
            transition: color 0.3s ease, border-color 0.3s ease;
        }

        .section-title {
            background: var(--bg-card);
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
            transition: background 0.3s ease;
        }

        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; color: var(--text-label); transition: color 0.3s ease; }

        .form-group input { 
            width: 100%; padding: 10px; box-sizing: border-box; 
            background-color: var(--input-bg); 
            border: 1px solid var(--input-border); 
            color: var(--input-text); 
            border-radius: 4px; transition: background-color 0.3s, border-color 0.3s, color 0.3s;
        }
        .form-group input:focus { outline: none; border-color: #38bdf8; background-color: var(--input-focus); }
        .form-group input::placeholder { color: var(--text-muted); }

        .card { 
            background: var(--bg-card); 
            backdrop-filter: blur(12px);
            padding: 20px; border-radius: 8px; margin-bottom: 40px; 
            border: 1px solid var(--divider); 
            box-shadow: 0 8px 16px rgba(0,0,0,0.3); 
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        .car-item { 
            background: var(--bg-card); 
            backdrop-filter: blur(12px);
            border: 1px solid var(--divider); 
            padding: 15px; margin-bottom: 15px; border-radius: 5px; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.2); 
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        @font-face {
            font-family: 'Sofachrome';
            src: url('/sofachrome_italic.otf') format('truetype');
            font-weight: normal;
            font-style: italic;
        }

        h2, h3 { 
            font-family: 'Sofachrome', sans-serif;
            font-style: italic;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px var(--title-shadow-1); 
        } 
        
  
        .btn { 
            font-family: 'Sofachrome', sans-serif;
            font-style: italic;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 10px !important; 
            padding: 12px 18px; 
            cursor: pointer; 
            border: none; 
            border-radius: 4px; 
            color: white !important; 
            margin-right: 5px; 
            text-decoration: none; 
            display: inline-block; 
            transition: background-color 0.3s ease, transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.2s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        .btn:active { 
            transform: translateY(1px); 
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
        }
        
        .controls-container {
            position: fixed; 
            top: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            z-index: 1000; 
        }

        .btn-control {
            background-color: var(--btn-controls-bg); 
            color: var(--text-main) !important;
            border: 1px solid var(--divider);
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
            backdrop-filter: blur(4px); 
            padding: 10px 15px;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Sofachrome', sans-serif;
            font-size: 10px;
            text-transform: uppercase;
            transition: background-color 0.3s, color 0.3s, transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.2s ease;
        }
        
        .btn-control:hover { 
            background-color: var(--bg-card); 
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 12px rgba(0,0,0,0.4);
        }
        
        .btn-control:active {
            transform: translateY(1px) scale(0.98);
            box-shadow: 0 2px 5px rgba(0,0,0,0.4);
        }


        .btn-submit { background-color: #0284c7; width: 100%; margin-top: 10px; } 
        .btn-submit:hover { background-color: #0369a1; }
        
        .btn-edit { background-color: #64748b; }
        .btn-edit:hover { background-color: #475569; }

        .btn-delete { background-color: #ef4444; }
        .btn-delete:hover { background-color: #dc2626; }

        .btn-back { 
            background-color: var(--btn-back-bg); 
            color: var(--btn-back-text) !important; 
            margin-bottom: 20px; 
            transition: background-color 0.3s, color 0.3s, transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.2s ease;
        }
        .btn-back:hover { background-color: var(--text-muted); color: white !important; }

        hr {
            border-top: 2px solid var(--divider);
            border-bottom: none;
            transition: border-color 0.3s ease;
        }
        
        .empty-message {
            color: var(--text-label); 
            font-style: italic; 
            background: var(--bg-card); 
            padding: 15px; 
            border-radius: 5px;
            transition: background 0.3s, color 0.3s;
        }
    </style>
</head>
<body>
    
    <div id="bg-image"></div>
    <div id="bg-overlay"></div>

    <div class="controls-container">
        <button id="toggle-theme-btn" class="btn-control">LIGHT THEME</button>
    </div>
    
    <div class="wrapper">

        <h1 class="main-title">CAR DATABASE MANAGER</h1>

        <a href="/" class="btn btn-back">⬅ Go back</a>

        {{#if editingCar}}
            <a href="/cars" class="btn btn-back">⬅ Скасувати редагування</a>
            <h2 class="section-title">Редагувати автомобіль: {{editingCar.car_brand}} {{editingCar.car_model}}</h2>
        {{else}}
            <h2 class="section-title">Додати новий автомобіль</h2>
        {{/if}}

        <div class="card">
            <form action="{{#if editingCar}}/cars/edit/{{editingCar.id}}{{else}}/cars{{/if}}" method="POST">
                
                <div class="form-group">
                    <label for="car_brand">Марка авто (Brand):</label>
                    <input type="text" id="car_brand" name="car_brand" value="{{editingCar.car_brand}}" placeholder="Наприклад: Audi" required>
                </div>

                <div class="form-group">
                    <label for="car_model">Модель (Model):</label>
                    <input type="text" id="car_model" name="car_model" value="{{editingCar.car_model}}" placeholder="Наприклад: A6" required>
                </div>

                <div class="form-group">
                    <label for="engine_type">Тип двигуна (Engine Type):</label>
                    <input type="text" id="engine_type" name="engine_type" value="{{editingCar.engine_type}}" placeholder="Наприклад: Бензин 3.0" required>
                </div>

                <div class="form-group">
                    <label for="horsepower">Кінські сили (Horsepower):</label>
                    <input type="number" id="horsepower" name="horsepower" value="{{editingCar.horsepower}}" placeholder="Наприклад: 340" min="0" required>
                </div>

                <div class="form-group">
                    <label for="weight">Вага, кг (Weight):</label>
                    <input type="number" id="weight" name="weight" value="{{editingCar.weight}}" placeholder="Наприклад: 1800" min="0" required>
                </div>

                <div class="form-group">
                    <label for="acceleration_0_to_100">Розгін 0-100 км/год (с):</label>
                    <input type="number" step="0.1" id="acceleration_0_to_100" name="acceleration_0_to_100" value="{{editingCar.acceleration_0_to_100}}" placeholder="Наприклад: 5.1" min="0" required>
                </div>

                <div class="form-group">
                    <label for="price">Ціна, $ (Price):</label>
                    <input type="number" id="price" name="price" value="{{editingCar.price}}" placeholder="Наприклад: 55000" min="0" required>
                </div>

                <div class="form-group">
                    <label for="image_url">Посилання на фото авто (URL):</label>
                    <input type="url" id="image_url" name="image_url" value="{{editingCar.image_url}}" placeholder="Наприклад: https://picsum.photos/500/300">
                </div>

                <button type="submit" class="btn btn-submit">
                    {{#if editingCar}}Зберегти зміни{{else}}Створити запис{{/if}}
                </button>
            </form>
        </div>

        <hr>

        <h2 class="section-title">Список автомобілів в базі</h2>

        <div id="cars-list">
            {{#each cars}}
                <div class="car-item" id="car-{{this.id}}">
                    <h3 style="margin-top: 0; color: var(--title-color);">{{this.car_brand}} {{this.car_model}}</h3>
                    
                    {{#if this.image_url}}
                        <img src="{{this.image_url}}" alt="Фото {{this.car_brand}}" style="width: 100%; height: 250px; object-fit: cover; border-radius: 5px; margin-bottom: 15px; border: 1px solid var(--input-border);">
                    {{/if}}

                    <p>
                        <strong>Двигун:</strong> {{this.engine_type}} | 
                        <strong>Потужність:</strong> {{this.horsepower}} к.с. <br>
                        <strong>Вага:</strong> {{this.weight}} кг | 
                        <strong>Розгін 0-100:</strong> {{this.acceleration_0_to_100}} с <br>
                        <strong>Ціна:</strong> ${{this.price}}
                    </p>
                    <p><small style="color: var(--text-muted);">Додано: {{this.created_at_date}} о {{this.created_at_time}}</small></p>
                    
                    <a href="/cars/edit/{{this.id}}" class="btn btn-edit">Редагувати</a>
                    <button class="btn btn-delete delete-btn" data-id="{{this.id}}">Видалити</button>
                </div>
            {{else}}
                <p class="empty-message">У базі поки що немає жодного автомобіля. Додайте перший!</p>
            {{/each}}
        </div>

    </div>

    <script>

        const themeBtn = document.getElementById('toggle-theme-btn');
        const currentTheme = localStorage.getItem('theme') || 'dark';

        document.documentElement.setAttribute('data-theme', currentTheme);
        themeBtn.textContent = currentTheme === 'dark' ? 'LIGHT THEME' : 'DARK THEME';

        themeBtn.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme');
            const targetTheme = current === 'dark' ? 'light' : 'dark';
            
            document.documentElement.setAttribute('data-theme', targetTheme);
            localStorage.setItem('theme', targetTheme);
            
            themeBtn.textContent = targetTheme === 'dark' ? 'LIGHT THEME' : 'DARK THEME';
        });

   
        document.querySelectorAll('.delete-btn').forEach(button => {
            button.addEventListener('click', async (event) => {
                const carId = event.target.getAttribute('data-id');
                if (confirm('Ви впевнені, що хочете назавжди видалити цю машину?')) {
                    try {
                        const response = await fetch(`/cars/${carId}`, { method: 'DELETE' });
                        if (response.ok) {
                            document.getElementById(`car-${carId}`).remove();
                        } else {
                            alert('Виникла помилка при видаленні.');
                        }
                    } catch (error) {
                        console.error('Помилка:', error);
                    }
                }
            });
        });
    </script>
</body>
</html>
